{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(echo $SHELL)",
      "Bash(nvim:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/criech/dotfiles/.vim/plugged/vim-claude-code/bin/vim-close-diff.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/criech/dotfiles/.vim/plugged/vim-claude-code/bin/vim-preview-diff.py"
          }
        ]
      }
    ]
  },
  "disabledMcpjsonServers": [
    "spyc"
  ]
}
